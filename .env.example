# ============================================================
# Variables de entorno — Reclamos CABA
# Copiar a .env.local (desarrollo) y cargar en el hosting (producción).
# NUNCA commitear .env.local (está en .gitignore).
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# SOLO server. Bypassa RLS. Cargar como variable NO pública en el hosting.
# Nunca exponer al cliente ni commitear.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# --- Gate del dashboard público (/public/*) ---
# OJO: son NEXT_PUBLIC (quedan visibles en el bundle del navegador), por lo que
# esto es ofuscación, no seguridad real. Aun así, en producción definí valores
# fuertes (no usar los defaults MASTER / 123456).
NEXT_PUBLIC_MASTER_USER=<usuario-master>
NEXT_PUBLIC_MASTER_PASS=<contraseña-fuerte>
